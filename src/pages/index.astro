---
import Layout from '../layouts/Layout.astro';
import { NftEvents } from '../components/NftEvents';
---

<Layout title="SWR NFT Events">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-nft-text mb-2">
        NFT Events
      </h1>
      <p class="text-nft-muted">
        Real-time NFT create and sell events on Ethereum · Powered by Alchemy + SWR
      </p>
      <div class="flex items-center gap-2 mt-3 text-xs text-nft-muted">
        <span class="w-2 h-2 rounded-full bg-nft-mint animate-pulse" />
        Live — refreshes every 15s
      </div>
    </header>

    <NftEvents client:only="react" />
  </main>
</Layout>
